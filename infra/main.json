                        "input": {
                          "name": "[format('allow-{0}', copyIndex('ipSecurityRestrictions'))]",
                          "ipAddressRange": "[trim(variables('parsedIpRestrictions')[copyIndex('ipSecurityRestrictions')])]",
                          "action": "Allow"
                        }
                      }
                    ],
                    "external": true,
                    "targetPort": 3000,
                    "transport": "auto",
                    "allowInsecure": false,
                    "corsPolicy": {
                      "allowedOrigins": "[if(empty(parameters('allowedOrigins')), createArray(format('https://{0}.{1}', parameters('name'), reference(resourceId('Microsoft.App/managedEnvironments', parameters('environmentName')), '2024-03-01').defaultDomain)), union(createArray(format('https://{0}.{1}', parameters('name'), reference(resourceId('Microsoft.App/managedEnvironments', parameters('environmentName')), '2024-03-01').defaultDomain)), split(parameters('allowedOrigins'), ',')))]",
                      "allowedMethods": [
                        "GET",
                        "POST"
                      ],
                      "allowedHeaders": [
                        "Content-Type",
                        "Authorization"
                      ],
                      "maxAge": 3600
                    }
                  },
                  "registries": [
                    {
                      "server": "[parameters('containerRegistryLoginServer')]",
                      "identity": "[parameters('managedIdentityId')]"
                    }
                  ],
                  "secrets": "[concat(createArray(createObject('name', 'github-client-id', 'value', parameters('githubClientId')), createObject('name', 'session-secret', 'value', parameters('sessionSecret'))), if(variables('hasAllowedUsers'), createArray(createObject('name', 'allowed-github-users', 'value', parameters('allowedGithubUsers'))), createArray()))]"
                },
                "template": {
                  "containers": [
                    {
                      "name": "copilot-unleashed",
                      "image": "[parameters('image')]",
                      "env": "[concat(createArray(createObject('name', 'NODE_ENV', 'value', 'production'), createObject('name', 'PORT', 'value', '3000'), createObject('name', 'BASE_URL', 'value', format('https://{0}.{1}', parameters('name'), reference(resourceId('Microsoft.App/managedEnvironments', parameters('environmentName')), '2024-03-01').defaultDomain)), createObject('name', 'GITHUB_CLIENT_ID', 'secretRef', 'github-client-id'), createObject('name', 'SESSION_SECRET', 'secretRef', 'session-secret'), createObject('name', 'SESSION_STORE_PATH', 'value', '/data/sessions'), createObject('name', 'SETTINGS_STORE_PATH', 'value', '/data/settings'), createObject('name', 'APPLICATIONINSIGHTS_CONNECTION_STRING', 'value', parameters('appInsightsConnectionString'))), if(variables('hasAllowedUsers'), createArray(createObject('name', 'ALLOWED_GITHUB_USERS', 'secretRef', 'allowed-github-users')), createArray()))]",
                      "volumeMounts": [
                        {
                          "volumeName": "persistent-data",
                          "mountPath": "/data"
                        }
                      ],
                      "resources": {
                        "cpu": "[json(parameters('cpuCores'))]",
                        "memory": "[parameters('memoryGi')]"
                      },
                      "probes": [
                        {
                          "type": "Liveness",
                          "httpGet": {
                            "path": "/health",
                            "port": 3000
                          },
                          "initialDelaySeconds": 10,
                          "periodSeconds": 30,
                          "failureThreshold": 3
                        },
                        {
                          "type": "Readiness",
                          "httpGet": {
                            "path": "/health",
                            "port": 3000
                          },
                          "initialDelaySeconds": 5,
                          "periodSeconds": 10,
                          "failureThreshold": 3
                        }
                      ]
                    }
                  ],
                  "volumes": [
                    {
                      "name": "persistent-data",
                      "storageName": "persistent-data",
                      "storageType": "AzureFile"
                    }
                  ],
                  "scale": {
                    "minReplicas": "[parameters('minReplicas')]",
                    "maxReplicas": "[parameters('maxReplicas')]",
                    "rules": [
                      {
                        "name": "http-rule",
                        "http": {
                          "metadata": {
                            "concurrentRequests": "10"
                          }
                        }
                      }
                    ]
                  }
                }
              },
              "dependsOn": [
                "[resourceId('Microsoft.App/managedEnvironments', parameters('environmentName'))]",
                "[resourceId('Microsoft.App/managedEnvironments/storages', parameters('environmentName'), 'persistent-data')]"
              ]
            }
          ],
          "outputs": {
            "fqdn": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.App/containerApps', parameters('name')), '2024-03-01').configuration.ingress.fqdn]"
            }
          }
        }
      },
      "dependsOn": [
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'container-registry')]",
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'managed-identity')]",
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'monitoring')]",
        "[subscriptionResourceId('Microsoft.Resources/resourceGroups', parameters('resourceGroupName'))]",
        "[extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'storage')]"
      ]
    }
  ],
  "outputs": {
    "AZURE_CONTAINER_REGISTRY_ENDPOINT": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'container-registry'), '2025-04-01').outputs.loginServer.value]"
    },
    "AZURE_CONTAINER_REGISTRY_NAME": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'container-registry'), '2025-04-01').outputs.name.value]"
    },
    "AZURE_CONTAINER_APP_FQDN": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'container-apps'), '2025-04-01').outputs.fqdn.value]"
    },
    "AZURE_RESOURCE_GROUP": {
      "type": "string",
      "value": "[parameters('resourceGroupName')]"
    },
    "AZURE_MANAGED_IDENTITY_CLIENT_ID": {
      "type": "string",
      "value": "[reference(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('resourceGroupName')), 'Microsoft.Resources/deployments', 'managed-identity'), '2025-04-01').outputs.clientId.value]"
    }
  }
}